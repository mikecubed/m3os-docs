---
import { getCollection } from 'astro:content';

import Layout from '../layouts/Layout.astro';
import PhaseCard from '../components/PhaseCard.astro';
import { buildHomepageModel } from '../lib/homepage';
import { sortPhases, type PhaseSummary } from '../lib/phase-utils';
import { withBase } from '../lib/site-paths';

const phases = sortPhases(
  (await getCollection('phases')).map((phase) => ({
    slug: phase.id,
    data: phase.data,
  })) satisfies PhaseSummary[],
);

const components = await getCollection('components');
const homepage = buildHomepageModel(phases, components);
const phaseTitleLookup = new Map(phases.map((phase) => [phase.slug, phase.data.title] as const));
---

<Layout title="m3OS Docs | Home">
  <section class="hero">
    <p class="eyebrow">{homepage.hero.eyebrow}</p>
    <h1>{homepage.hero.title}</h1>
    <p class="hero__lede">{homepage.hero.lede}</p>
    <div class="hero__actions">
      <a class="button button--primary" href={withBase('/phases/')}>Explore phases</a>
      <a class="button" href={withBase('/components/')}>Browse components</a>
    </div>
  </section>

  <section class="stats-grid">
    {
      homepage.stats.map((stat) => (
        <article class="stat-card">
          <p class="eyebrow">{stat.label}</p>
          <strong>{stat.value}</strong>
          <span>{stat.detail}</span>
        </article>
      ))
    }
  </section>

  <section class="panel-grid">
    <article class="panel panel--accent">
      <p class="eyebrow">How to use this site</p>
      <ul>
        {homepage.learningPath.map((item) => (
          <li>
            <strong>{item.title}</strong> — {item.description}
          </li>
        ))}
      </ul>
    </article>
    <article class="panel panel--contrast">
      <p class="eyebrow">What each phase page explains</p>
      <ul>
        {homepage.phasePageHighlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section-stack">
    <div class="section-heading">
      <p class="eyebrow">Start here</p>
      <h2>Foundational phases worth reading first</h2>
    </div>
    <div class="card-grid">
      {homepage.foundations.map((phase) => <PhaseCard phase={phase} />)}
    </div>
  </section>

  <section class="section-stack">
    <div class="section-heading">
      <p class="eyebrow">Look ahead</p>
      <h2>Planned work that expands the system</h2>
    </div>
    <div class="card-grid">
      {homepage.advancedPhases.map((phase) => <PhaseCard phase={phase} />)}
    </div>
  </section>

  <section class="section-stack">
    <div class="section-heading">
      <p class="eyebrow">Subsystem map</p>
      <h2>Jump into the components that span multiple phases</h2>
    </div>
    <div class="card-grid">
      {
        homepage.featuredComponents.map((component) => (
          <a class="phase-card" href={withBase(`/components/${component.id}/`)}>
            <div class="phase-card__header">
              <p class="eyebrow">Introduced in</p>
              <span class="status-badge status-badge--planned">
                {phaseTitleLookup.get(component.data.introducedIn) ?? component.data.introducedIn}
              </span>
            </div>
            <h3>{component.data.title}</h3>
            <p>{component.data.summary}</p>
            <div class="phase-card__footer">
              <span>{component.data.touchedBy.length} later phase(s)</span>
              <span>{component.data.keyFiles.length} key file(s)</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
