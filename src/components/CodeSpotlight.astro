---
interface Props {
  title: string;
  file: string;
  lines: string;
  summary: string;
  githubUrl?: string;
  steps?: Array<{
    title: string;
    summary: string;
    lines?: string;
  }>;
  snippet?: string;
  snippetLanguage?: string;
}

const { file, githubUrl, lines, snippet, snippetLanguage, steps = [], summary, title } = Astro.props;
---

<section class="code-spotlight">
  <div class="code-spotlight__header">
    <div>
      <p class="eyebrow">Code spotlight</p>
      <h3>{title}</h3>
    </div>
    <div class="code-spotlight__meta">
      <span>{file}</span>
      <span>{lines}</span>
    </div>
  </div>
  <p>{summary}</p>
  {
    steps.length > 0 && (
      <ol class="code-spotlight__steps">
        {steps.map((step) => (
          <li>
            <div class="code-spotlight__step-header">
              <strong>{step.title}</strong>
              {step.lines && <span>{step.lines}</span>}
            </div>
            <p>{step.summary}</p>
          </li>
        ))}
      </ol>
    )
  }
  {snippet && (
    <pre class="code-spotlight__snippet"><code class={`language-${snippetLanguage ?? 'text'}`}>{snippet}</code></pre>
  )}
  {githubUrl && (
    <p class="code-spotlight__link">
      <a href={githubUrl} target="_blank" rel="noreferrer">
        View on GitHub
      </a>
    </p>
  )}
</section>
