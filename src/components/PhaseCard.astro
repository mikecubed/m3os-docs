---
import StatusBadge from './StatusBadge.astro';
import type { PhaseSummary } from '../lib/phase-utils';

interface Props {
  phase: PhaseSummary;
}

const { phase } = Astro.props;
---

<article class="phase-card">
  <div class="phase-card__header">
    <p class="eyebrow">Phase {phase.data.phase.toString().padStart(2, '0')}</p>
    <StatusBadge status={phase.data.status} />
  </div>
  <h3>
    <a href={`/phases/${phase.slug}/`}>{phase.data.title}</a>
  </h3>
  <p>{phase.data.summary}</p>
  <div class="phase-card__footer">
    <span>{phase.data.category}</span>
    <span>{phase.data.buildsOn.length} prerequisite(s)</span>
  </div>
</article>
